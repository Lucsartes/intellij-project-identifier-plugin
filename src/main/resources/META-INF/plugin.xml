<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.lucsartes.intellijprojectidentifierplugin</id>
    <name>Project Identifier</name>
    <description>Adds a subtle, low-opacity text watermark to the editor background per project to help distinguish multiple open projects.</description>
    <vendor email="lucsartes.xels@gmail.com">Lucsartes</vendor>
    <resource-bundle>messages.MyBundle</resource-bundle>

	<version>0.0.8</version>

    <depends>com.intellij.modules.platform</depends>

    <!-- Optional dependency on the bundled Git plugin. When present, git-integration.xml swaps in the
         event-driven GitBranchProvider; when absent/disabled the plugin still loads and falls back to
         reading .git/HEAD, so the ${branch} placeholder degrades gracefully. -->
    <depends optional="true" config-file="git-integration.xml">Git4Idea</depends>

	<resource-bundle>messages.MyBundle</resource-bundle>

	<extensions defaultExtensionNs="com.intellij">
        <!-- Project-level service that persists settings and implements ProjectSettingsPort -->
        <projectService
            serviceInterface="com.github.lucsartes.intellijprojectidentifierplugin.ports.ProjectSettingsPort"
            serviceImplementation="com.github.lucsartes.intellijprojectidentifierplugin.adapters.intellij.IntelliJSettingsService"/>

        <!-- Application-level service that persists application settings and implements ApplicationSettingsPort -->
        <applicationService
            serviceInterface="com.github.lucsartes.intellijprojectidentifierplugin.ports.ApplicationSettingsPort"
            serviceImplementation="com.github.lucsartes.intellijprojectidentifierplugin.adapters.intellij.IntelliJApplicationSettingsService"/>

        <!-- Project-level service that implements BackgroundImagePort via IntelliJ adapter -->
        <projectService
            serviceInterface="com.github.lucsartes.intellijprojectidentifierplugin.ports.BackgroundImagePort"
            serviceImplementation="com.github.lucsartes.intellijprojectidentifierplugin.adapters.intellij.IntelliJBackgroundImageAdapter"/>

        <!-- Default BranchProvider: zero-dependency, reads .git/HEAD. Overridden by GitBranchProvider
             (git-integration.xml) when the bundled Git plugin is available. -->
        <projectService
            serviceInterface="com.github.lucsartes.intellijprojectidentifierplugin.ports.BranchProvider"
            serviceImplementation="com.github.lucsartes.intellijprojectidentifierplugin.adapters.intellij.FileSystemBranchProvider"/>

        <!-- Project startup activity -->
        <postStartupActivity implementation="com.github.lucsartes.intellijprojectidentifierplugin.adapters.intellij.ProjectStartupActivity"/>

        <!-- Settings UI -->
        <applicationConfigurable
                parentId="appearance"
                instance="com.github.lucsartes.intellijprojectidentifierplugin.adapters.intellij.IntelliJApplicationSettingsConfigurable"
                id="com.github.lucsartes.intellijprojectidentifierplugin.application.settings"
                bundle="messages.MyBundle"
                key="settings.parent.title"/>

        <projectConfigurable
                parentId="com.github.lucsartes.intellijprojectidentifierplugin.application.settings"
                instance="com.github.lucsartes.intellijprojectidentifierplugin.adapters.intellij.IntelliJSettingsConfigurable"
                id="com.github.lucsartes.intellijprojectidentifierplugin.settings"
                bundle="messages.MyBundle"
                key="settings.child.title"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
		<errorHandler implementation="com.intellij.diagnostic.JetBrainsMarketplaceErrorReportSubmitter"/>
	</extensions>
</idea-plugin>
